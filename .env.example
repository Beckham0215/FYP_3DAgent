# Copy this file to .env and fill in your own values.
# .env is git-ignored and must NEVER be committed.

# Flask session secret — use a long random string in production.
SECRET_KEY=replace-with-a-random-string

# Groq API (https://console.groq.com/) — each user supplies their own key.
GROQ_API_KEY=your-groq-api-key
# Optional second key; used as automatic fallback on rate-limit.
GROQ_API_KEY_2=
# Chat model. Default if unset: llama-3.3-70b-versatile
GROQ_MODEL=llama-3.3-70b-versatile

# Matterport Showcase SDK key (https://matterport.com/)
MATTERPORT_SDK_KEY=your-matterport-sdk-key
